# Servidor
PORT=3000
NODE_ENV=production

# Modo dev local (JSON file store, sem Firebase, sem Maps)
# Em produção: USE_SQLITE=false
USE_SQLITE=false

# Firebase Admin SDK
# Gere em: Firebase Console → Configurações do projeto → Contas de serviço
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Google Maps Routes API
# Ative em: Google Cloud Console → APIs → Routes API
GOOGLE_MAPS_ROUTES_KEY=

# Upstash Redis (opcional — rate limiting por usuário)
# Crie em: https://upstash.com
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

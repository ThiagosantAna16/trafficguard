# Servidor
PORT=3000
NODE_ENV=production

# Banco de dados
# Em produção: Postgres do Railway (a variável é injetada automaticamente ao
# referenciar o serviço Postgres). Sem DATABASE_URL, cai no store local em JSON (dev).
DATABASE_URL=

# Autenticação (JWT próprio) — OBRIGATÓRIO em produção. Gere um segredo forte:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# TomTom API (rotas + tráfego em tempo real)
# Crie a chave grátis em: https://developer.tomtom.com (tier free: 2.500 req/dia)
TOMTOM_API_KEY=

# Redis (cache + quota da API de rotas)
# No Railway: injetado ao referenciar o serviço Redis. Sem isso, usa cache em memória.
REDIS_URL=
